# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# satellite output files (generated by api.py, named output_{lat}_{lon}.json)
output_*.json
!components.json

# ── Python ─────────────────────────────────────────────────────
# Bytecode cache produced by uvicorn / python at runtime
__pycache__/
*.py[cod]
*$py.class

# Virtual environments (if created locally)
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg

# ── Jupyter ────────────────────────────────────────────────────
# Auto-save checkpoints created when editing the notebook
.ipynb_checkpoints/

# ── GeoTIFF / raster intermediates ────────────────────────────
# In-memory in production, but guard against accidental local saves
*.tif
*.tiff

# ── IDE ────────────────────────────────────────────────────────
# JetBrains (PyCharm / WebStorm / IntelliJ)
.idea/
# VS Code
.vscode/

# ── Duplicate / scratch files ──────────────────────────────────
README copy.md
